---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Page-specific social image; falls back to the default site card. */
  ogImage?: ImageMetadata;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, ogImageAlt, ogType = 'website' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Social preview image. Page images are re-encoded as JPEG — some scrapers
// (LinkedIn among them) still choke on WebP og:image.
const pageOg = ogImage ? await getImage({ src: ogImage, width: 1200, format: 'jpeg' }) : null;
const ogImageURL = new URL(pageOg ? pageOg.src : '/og-default.png', Astro.site);
const ogImageWidth = 1200;
const ogImageHeight =
  pageOg && ogImage ? Math.round((ogImage.height / ogImage.width) * 1200) : 630;
const ogImageAltText = ogImageAlt ?? 'Bruce — Web Development for Small Businesses';

const navLinks = [
  { href: '/work/', label: 'Work' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

// Trailing slashes vary between dev and build output
const normalize = (path: string) => path.replace(/\/+$/, '') || '/';
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) =>
  currentPath === normalize(href) || currentPath.startsWith(`${normalize(href)}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content="Bruce — Web Development" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAltText} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="border-b border-edge">
      <nav
        aria-label="Main"
        class="mx-auto flex w-full max-w-5xl flex-wrap items-baseline justify-between gap-x-8 gap-y-1 px-5 py-5 sm:px-8"
      >
        <a href="/" class="font-display text-lg font-semibold tracking-tight text-ink">
          Bruce — Web Development
        </a>
        <ul class="flex flex-wrap items-baseline gap-x-6 gap-y-1 text-sm font-medium">
          {
            navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isActive(href) ? 'page' : undefined}
                  class:list={[
                    'transition-colors hover:text-ink',
                    isActive(href)
                      ? 'text-ink underline decoration-pine-600 decoration-2 underline-offset-8'
                      : 'text-muted',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>
    <main id="main" class="flex-1">
      <slot />
    </main>
    <footer class="bg-pine-950">
      <div class="mx-auto w-full max-w-5xl px-5 py-10 sm:px-8">
        <div class="tick" aria-hidden="true"></div>
        <p class="text-sm text-fog">
          © {new Date().getFullYear()} Bruce — Web Development Services · Winnipeg, Canada
        </p>
      </div>
    </footer>
  </body>
</html>
