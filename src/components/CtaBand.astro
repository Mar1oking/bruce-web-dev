---
interface Props {
  heading: string;
  body: string;
  buttonLabel?: string;
  href?: string;
}

const { heading, body, buttonLabel = 'Get in touch', href = '/contact/' } = Astro.props;
---

<section class="bg-pine-800">
  <div class="mx-auto w-full max-w-5xl px-5 py-24 sm:px-8 md:py-36">
    <h2 class="max-w-[24ch] text-4xl font-semibold tracking-tight text-white sm:text-5xl">
      {heading}
    </h2>
    <p class="mt-4 max-w-prose text-lg leading-relaxed text-fog">{body}</p>
    <a
      href={href}
      class="mt-8 inline-block rounded-md bg-paper px-5 py-2.5 font-medium text-pine-800 transition-colors hover:bg-white"
    >
      {buttonLabel}
    </a>
  </div>
</section>
