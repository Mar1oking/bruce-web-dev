---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Bruce Web Development"
  description="That page doesn't exist. Head back to the homepage or browse my recent work."
>
  <section class="mx-auto w-full max-w-5xl px-5 pt-24 pb-32 text-center sm:px-8 md:pt-40">
    <div aria-hidden="true" class="mx-auto mb-8 h-1 w-12 bg-sand"></div>
    <p class="meta-label">404</p>
    <h1 class="mx-auto mt-4 max-w-[22ch] text-4xl font-semibold tracking-tight sm:text-5xl">
      This page doesn't exist
    </h1>
    <p class="mx-auto mt-6 max-w-prose text-lg leading-relaxed">
      The link may be old or mistyped. Everything worth seeing is one click away.
    </p>
    <p class="mt-10">
      <a href="/" class="btn-primary">Back to home</a>
      <span aria-hidden="true" class="mx-3 text-muted">·</span>
      <a href="/work/" class="text-link">See my work</a>
    </p>
  </section>
</BaseLayout>
