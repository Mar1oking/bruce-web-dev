---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Bruce Web Development"
  description="Get in touch about your website project — email, phone, or the contact form. Based in Winnipeg, working with small businesses anywhere."
>
  <div class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 md:py-20">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Contact</h1>
    <p class="mt-4 max-w-prose text-lg leading-relaxed">
      Tell me a bit about your business and what you need — I'll reply within
      a day or two.
    </p>

    <div class="mt-12 grid gap-12 md:grid-cols-[1fr_1.4fr] md:gap-16">
      <ul class="space-y-3 leading-relaxed">
        <li>Email: <a href="mailto:hello@example.com" class="text-link">hello@example.com</a></li>
        <li>Phone: <a href="tel:+12040000000" class="text-link">(204) 000-0000</a></li>
      </ul>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-5"
      >
        <p hidden>
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <input type="hidden" name="form-name" value="contact" />
        <p>
          <label for="name" class="block text-sm font-medium text-ink">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            autocomplete="name"
            class="mt-1.5 block w-full rounded-md border border-edge bg-white px-3.5 py-2.5 text-ink"
          />
        </p>
        <p>
          <label for="email" class="block text-sm font-medium text-ink">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            autocomplete="email"
            class="mt-1.5 block w-full rounded-md border border-edge bg-white px-3.5 py-2.5 text-ink"
          />
        </p>
        <p>
          <label for="message" class="block text-sm font-medium text-ink">What do you need?</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="mt-1.5 block w-full rounded-md border border-edge bg-white px-3.5 py-2.5 text-ink"
          ></textarea>
        </p>
        <button type="submit" class="btn-primary cursor-pointer">Send message</button>
      </form>
    </div>
  </div>
</BaseLayout>
