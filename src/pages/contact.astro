---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Bruce Web Development"
  description="Get in touch about your website project — email, phone, or the contact form. Based in Winnipeg, working with small businesses anywhere."
>
  <h1>Contact</h1>
  <p>
    Tell me a bit about your business and what you need — I'll reply within
    a day or two.
  </p>

  <ul>
    <li>Email: <a href="mailto:hello@example.com">hello@example.com</a></li>
    <li>Phone: <a href="tel:+12040000000">(204) 000-0000</a></li>
  </ul>

  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <p hidden>
      <label>Don't fill this out if you're human: <input name="bot-field" /></label>
    </p>
    <input type="hidden" name="form-name" value="contact" />
    <p>
      <label for="name">Name</label>
      <input id="name" type="text" name="name" required autocomplete="name" />
    </p>
    <p>
      <label for="email">Email</label>
      <input id="email" type="email" name="email" required autocomplete="email" />
    </p>
    <p>
      <label for="message">What do you need?</label>
      <textarea id="message" name="message" rows="6" required></textarea>
    </p>
    <button type="submit">Send message</button>
  </form>
</BaseLayout>
