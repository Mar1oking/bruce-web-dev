---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('work')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Work — Bruce Web Development"
  description="Case studies of websites I've built for small businesses: the problem, what I did, and the result."
>
  <h1>Work</h1>
  {
    projects.length === 0 ? (
      <p>Case studies are coming soon. In the meantime, <a href="/contact/">get in touch</a> and I'll walk you through what I'm working on.</p>
    ) : (
      <ul>
        {projects.map((project) => (
          <li>
            <article>
              <a href={`/work/${project.id}/`}>
                <Image src={project.data.cover} alt={`${project.data.title} — cover image`} width={800} />
                <h2>{project.data.title}</h2>
              </a>
              <p>{project.data.summary}</p>
              <ul aria-label="Technologies used">
                {project.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
