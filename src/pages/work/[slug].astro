---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout
  title={`${project.data.title} — Bruce Web Development`}
  description={project.data.summary}
>
  <article>
    <header>
      <h1>{project.data.title}</h1>
      <p>{project.data.summary}</p>
      <dl>
        <dt>Client</dt>
        <dd>{project.data.client}</dd>
        <dt>Date</dt>
        <dd><time datetime={project.data.date.toISOString()}>{formattedDate}</time></dd>
      </dl>
      <ul aria-label="Technologies used">
        {project.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
      <Image src={project.data.cover} alt={`${project.data.title} — cover image`} width={1200} />
    </header>

    <section>
      <h2>The problem</h2>
      <p>{project.data.problem}</p>
    </section>

    <section>
      <h2>What I did</h2>
      <p>{project.data.solution}</p>
    </section>

    <section>
      <h2>The result</h2>
      <p>{project.data.result}</p>
    </section>

    {
      project.data.images.length > 0 && (
        <section>
          <h2>Screenshots</h2>
          <ul>
            {project.data.images.map((img, i) => (
              <li>
                <Image src={img} alt={`${project.data.title} — screenshot ${i + 1}`} width={1200} />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <Content />
  </article>

  <p><a href="/work/">← All work</a></p>
</BaseLayout>
