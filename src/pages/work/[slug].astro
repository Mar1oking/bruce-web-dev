---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout
  title={`${project.data.title} — Bruce Web Development`}
  description={project.data.summary}
>
  <article class="mx-auto w-full max-w-3xl px-5 pt-16 sm:px-8 md:pt-20">
    <header>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl">
        {project.data.title}
      </h1>
      <p class="mt-4 max-w-prose text-lg leading-relaxed text-muted">{project.data.summary}</p>
      <dl class="mt-8 flex flex-wrap gap-x-10 gap-y-4">
        <div>
          <dt class="meta-label">Client</dt>
          <dd class="mt-1 font-medium text-ink">{project.data.client}</dd>
        </div>
        <div>
          <dt class="meta-label">Date</dt>
          <dd class="mt-1 font-medium text-ink">
            <time datetime={project.data.date.toISOString()}>{formattedDate}</time>
          </dd>
        </div>
      </dl>
      <ul aria-label="Technologies used" class="mt-6 flex flex-wrap gap-x-3 gap-y-1">
        {project.data.tags.map((tag) => <li class="meta-label">{tag}</li>)}
      </ul>
      <Image
        src={project.data.cover}
        alt={`${project.data.title} — cover image`}
        width={1200}
        class="mt-10 w-full rounded-lg border border-edge"
      />
    </header>

    <section class="mt-12">
      <h2 class="text-2xl font-semibold tracking-tight">The problem</h2>
      <p class="mt-4 max-w-prose leading-relaxed">{project.data.problem}</p>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-semibold tracking-tight">What I did</h2>
      <p class="mt-4 max-w-prose leading-relaxed">{project.data.solution}</p>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-semibold tracking-tight">The result</h2>
      <p class="mt-4 max-w-prose leading-relaxed">{project.data.result}</p>
    </section>

    {
      project.data.images.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold tracking-tight">Screenshots</h2>
          <ul class="mt-6 grid gap-6 sm:grid-cols-2">
            {project.data.images.map((img, i) => (
              <li>
                <Image
                  src={img}
                  alt={`${project.data.title} — screenshot ${i + 1}`}
                  width={1200}
                  class="w-full rounded-lg border border-edge"
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="md-content mt-12">
      <Content />
    </div>
  </article>

  <p class="mx-auto w-full max-w-3xl px-5 pt-12 pb-16 sm:px-8">
    <a href="/work/" class="text-link">← All work</a>
  </p>

  <CtaBand
    heading="Want something like this for your business?"
    body="Tell me what you need — I'll reply with honest advice and a clear quote."
  />
</BaseLayout>
