---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const featured = (await getCollection('work', ({ data }) => data.featured)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)[0];

const benefits = [
  'A fast site that looks good on every phone and laptop',
  'Search-engine friendly from day one',
  'Straightforward communication — no jargon, no surprises',
];

const steps = [
  {
    title: 'Say hello',
    body: 'Tell me about your business through the contact form. No obligation, no sales pitch.',
  },
  {
    title: 'Plan and quote',
    body: 'We agree on what the site needs, page by page, and I give you a quote before any work starts.',
  },
  {
    title: 'Build and review',
    body: "I build the site and send you progress links along the way. You tell me what's off; I fix it.",
  },
  {
    title: 'Launch and handoff',
    body: 'Your site goes live, and I show you how to make updates yourself.',
  },
];
---

<BaseLayout
  title="Bruce — Web Development for Small Businesses"
  description="Fast, affordable websites for small businesses, built by a student developer in Winnipeg. See my work and get in touch for a quote."
>
  <section class="mx-auto w-full max-w-5xl px-5 pt-20 pb-16 sm:px-8 md:pt-28 md:pb-24">
    <div aria-hidden="true" class="mb-8 h-1 w-12 bg-pine-600"></div>
    <h1 class="max-w-[22ch] text-4xl font-semibold tracking-tight sm:text-5xl md:text-6xl">
      Websites that win your small business more customers
    </h1>
    <p class="mt-6 max-w-prose text-lg leading-relaxed">
      I'm Bruce, a student web developer in Winnipeg. I build fast, modern
      websites for small businesses — clear pricing, honest advice, and a
      site you can actually update yourself.
    </p>
    <a href="/contact/" class="btn-primary mt-10">Get in touch</a>
  </section>

  {
    featured && (
      <section class="border-y border-edge bg-band">
        <div class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 md:py-20">
          <div class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-2">
            <p class="meta-label">Featured work</p>
            <a href="/work/" class="text-link">All work</a>
          </div>
          <div class="mt-8 grid items-center gap-10 md:grid-cols-[3fr_2fr] md:gap-16">
            <a href={`/work/${featured.id}/`} class="group block">
              <Image
                src={featured.data.cover}
                alt={`${featured.data.title} — cover image`}
                width={1000}
                class="aspect-[16/10] w-full rounded-lg border border-edge object-cover transition-colors group-hover:border-pine-300"
              />
            </a>
            <div>
              <h2 class="text-3xl font-semibold tracking-tight">
                <a
                  href={`/work/${featured.id}/`}
                  class="transition-colors hover:text-pine-700"
                >
                  {featured.data.title}
                </a>
              </h2>
              <p class="mt-3 leading-relaxed">{featured.data.summary}</p>
              <ul aria-label="Technologies used" class="mt-5 flex flex-wrap gap-x-3 gap-y-1">
                {featured.data.tags.map((tag) => (
                  <li class="meta-label">{tag}</li>
                ))}
              </ul>
              <a href={`/work/${featured.id}/`} class="text-link mt-6 inline-block">
                Read the case study
              </a>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <section
    class="mx-auto grid w-full max-w-5xl gap-x-16 gap-y-8 px-5 py-16 sm:px-8 md:grid-cols-[1fr_1.6fr] md:py-20"
  >
    <h2 class="text-2xl font-semibold tracking-tight">What you get</h2>
    <ul class="space-y-4">
      {
        benefits.map((benefit) => (
          <li class="flex gap-3">
            <svg
              class="mt-1.5 size-4 shrink-0 text-pine-600"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M2.5 8.5l3.5 3.5 7.5-8"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>{benefit}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="border-y border-edge bg-band">
    <div class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 md:py-20">
      <div class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-2">
        <h2 class="text-2xl font-semibold tracking-tight">How I can help</h2>
        <a href="/services/" class="text-link">Services &amp; pricing</a>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <a
          href="/services/"
          class="group flex flex-col rounded-lg border border-edge bg-white p-6 transition-colors hover:border-pine-300"
        >
          <h3
            class="text-lg font-semibold tracking-tight transition-colors group-hover:text-pine-700"
          >
            New business website
          </h3>
          <p class="mt-2 leading-relaxed">
            A fast, mobile-friendly site that tells customers what you do and
            how to reach you.
          </p>
        </a>
        <a
          href="/services/"
          class="group flex flex-col rounded-lg border border-edge bg-white p-6 transition-colors hover:border-pine-300"
        >
          <h3
            class="text-lg font-semibold tracking-tight transition-colors group-hover:text-pine-700"
          >
            Website redesign
          </h3>
          <p class="mt-2 leading-relaxed">
            A modern rebuild for a site that looks dated or loads slowly —
            keeping what already works.
          </p>
        </a>
        <a
          href="/services/"
          class="group flex flex-col rounded-lg border border-edge bg-white p-6 transition-colors hover:border-pine-300"
        >
          <h3
            class="text-lg font-semibold tracking-tight transition-colors group-hover:text-pine-700"
          >
            Updates &amp; maintenance
          </h3>
          <p class="mt-2 leading-relaxed">
            Content changes and new pages, so your site stays current without
            you touching code.
          </p>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 md:py-20">
    <h2 class="text-2xl font-semibold tracking-tight">How it works</h2>
    <p class="mt-3 max-w-prose leading-relaxed">
      No mystery — this is what working with me looks like, start to finish.
    </p>
    <ol role="list" class="mt-10 grid gap-x-8 gap-y-10 sm:grid-cols-2 md:grid-cols-4">
      {
        steps.map((step, i) => (
          <li class="border-t border-edge pt-5">
            <p aria-hidden="true" class="font-display text-3xl font-semibold text-pine-600">
              {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="mt-3 text-lg font-semibold tracking-tight">{step.title}</h3>
            <p class="mt-2 leading-relaxed">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <CtaBand
    heading="Have a project in mind?"
    body="Tell me what your business needs — I'll reply with honest advice and a clear quote."
  />
</BaseLayout>
